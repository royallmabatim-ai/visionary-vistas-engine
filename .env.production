# Production Environment Configuration
# Copy this file to .env.production and update values for your production environment

# API Configuration
VITE_API_URL=https://api.royalmabati.com
VITE_APP_ENV=production

# Email Configuration
VITE_CONTACT_EMAIL=salesroyalmabati@gmail.com
VITE_NOTIFICATION_EMAIL=notifications@royalmabati.com

# Phone Configuration
VITE_PHONE_NUMBER=+254755199726
VITE_WHATSAPP_NUMBER=+254755199726

# Social Media
VITE_FACEBOOK_URL=https://www.facebook.com/share/1AMKUYhVgU/
VITE_TWITTER_URL=https://twitter.com/royalmabati

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=
VITE_GOOGLE_TAG_MANAGER_ID=

# Security
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true

# Site URLs
VITE_SITE_URL=https://www.royalmabati.com
VITE_CDN_URL=https://cdn.royalmabati.com

# Feature Flags
VITE_ENABLE_QUOTE_FORM=true
VITE_ENABLE_CHAT=false
