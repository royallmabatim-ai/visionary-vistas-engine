# Environment Configuration Template
# Copy this file to .env.local and update with your values

# Application
VITE_APP_TITLE=Visionary Vistas Engine
VITE_APP_DESCRIPTION=Professional Roofing Solutions

# API Configuration
VITE_API_BASE_URL=https://api.yourdomain.com
VITE_API_TIMEOUT=30000

# Analytics
VITE_ANALYTICS_ID=
VITE_ANALYTICS_ENABLED=true

# Sentry (Error Tracking)
VITE_SENTRY_DSN=
VITE_SENTRY_ENABLED=false
VITE_SENTRY_ENVIRONMENT=production

# Feature Flags
VITE_FEATURE_QUOTES=true
VITE_FEATURE_TESTIMONIALS=true
VITE_FEATURE_PRODUCTS=true

# Contact Information
VITE_CONTACT_EMAIL=info@yourdomain.com
VITE_CONTACT_PHONE=+1-234-567-8900

# Social Media
VITE_SOCIAL_FACEBOOK=
VITE_SOCIAL_TWITTER=
VITE_SOCIAL_INSTAGRAM=
VITE_SOCIAL_LINKEDIN=
